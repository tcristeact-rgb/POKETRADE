APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# Orígenes permitidos por CORS (lista separada por comas, sin barra final).
# En local cubre Live Server y `npx serve`. En producción pon la URL del frontend,
# p. ej. FRONTEND_URL=https://poketrade.tudominio.com
FRONTEND_URL="http://localhost:5500,http://127.0.0.1:5500,http://localhost:3000"

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─── Base de datos ──────────────────────────────────────────────────
# DESARROLLO LOCAL: SQLite por defecto (cero configuración, sin servidor).
DB_CONNECTION=sqlite

# PRODUCCIÓN (Render + Supabase): PostgreSQL. Comenta la línea DB_CONNECTION
# de arriba y descomenta/rellena estas. Los valores salen del "Session pooler"
# de Supabase (Project Settings → Database → Connection string → Session pooler),
# que es la ruta IPv4 — la conexión directa de Supabase es solo IPv6 y Render
# no la alcanza.
# DB_CONNECTION=pgsql
# DB_HOST=aws-0-<region>.pooler.supabase.com   # host del Session pooler (IPv4)
# DB_PORT=5432                                  # puerto del Session pooler
# DB_DATABASE=postgres                          # nombre de la BD en Supabase
# DB_USERNAME=postgres.<project-ref>            # el usuario incluye el ref del proyecto
# DB_PASSWORD=<tu-password-de-supabase>         # NUNCA subir al repo
# DB_SSLMODE=require                            # Supabase exige conexión SSL

# Driver de sesión. Este backend es una API stateless (autenticación con JWT
# en cabecera) y NO existe tabla `sessions` en las migraciones, por lo que se
# usa 'array' (sesión en memoria por petición) tanto en local como en producción.
# No usar 'database' aquí: fallaría al no existir la tabla.
SESSION_DRIVER=array
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
